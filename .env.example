# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/warroom?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
SOCKET_PORT="3001"
NODE_ENV="development"

# File Storage
# Provider: "local" (dev) or "s3" (prod)
STORAGE_PROVIDER="local"
STORAGE_SECRET="change-me-to-random-secret-in-production"

# S3-compatible config (only needed when STORAGE_PROVIDER=s3)
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"
# S3_BUCKET="warroom-uploads"
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
